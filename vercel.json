{
  "version": 2,
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "*.jpg",
      "use": "@vercel/static"
    },
    {
      "src": "*.JPG",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/(?!.*\\.(jpg|JPG|jpeg|png|gif|webp|svg|ico)$).*", "dest": "/index.html" }
  ]
}
